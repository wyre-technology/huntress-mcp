{
  "name": "huntress-mcp",
  "version": "1.0.7",
  "description": "MCP server for the Huntress cybersecurity platform",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "huntress-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "pack:mcpb": "node scripts/pack-mcpb.cjs",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "keywords": [
    "huntress",
    "mcp",
    "msp",
    "security",
    "edr",
    "model-context-protocol"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@wyre-technology/node-huntress": "^1.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "semantic-release": "^25.0.8",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
